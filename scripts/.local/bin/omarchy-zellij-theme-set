#!/usr/bin/env bash
set -euo pipefail

GENERATED_THEME="$HOME/.config/omarchy/current/theme/zellij.kdl"
WS_CONFIG="$HOME/.config/zellij/ws-config.kdl"
START_MARKER="// >>> dotfiles-managed omarchy-zellij-theme >>>"
END_MARKER="// <<< dotfiles-managed omarchy-zellij-theme <<<"

if [[ ! -f "$GENERATED_THEME" || ! -f "$WS_CONFIG" ]]; then
  exit 0
fi

theme_block="$(sed -E 's/([0-9]{1,3}),([0-9]{1,3}),([0-9]{1,3})/\1 \2 \3/g' "$GENERATED_THEME")"

python3 - "$WS_CONFIG" "$START_MARKER" "$END_MARKER" "$theme_block" <<'PY'
import pathlib
import re
import sys

path = pathlib.Path(sys.argv[1])
start = sys.argv[2]
end = sys.argv[3]
theme = sys.argv[4]

text = path.read_text()

pattern = re.compile(
    rf"\n?{re.escape(start)}\n.*?\n{re.escape(end)}\n?",
    re.S,
)
text = pattern.sub("\n", text)

if 'theme "omarchy"' not in text:
    text = re.sub(r'^theme\s+"[^"]+"', 'theme "omarchy"', text, count=1, flags=re.M)
    if 'theme "omarchy"' not in text:
        text = text.rstrip() + '\n\ntheme "omarchy"\n'

text = text.rstrip() + f"\n\n{start}\n{theme}\n{end}\n"
path.write_text(text)
PY
