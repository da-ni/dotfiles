#!/usr/bin/env bash
set -euo pipefail

cat <<'EOF'
Workspace keys

Commands:
  ws add            Add project tab
  ws add --recent   Add project tab from recent zoxide dirs
  ws git            Open lazygit in floating pane
  ws yazi           Open yazi in floating pane
  ws doctor         Check workspace dependencies and paths
  ws reset          Delete studio session and return to shell
  ws restart        Delete studio session and recreate immediately
  ws help           Show this help

Navigation:
  Alt-h/j/k/l       Move focus between panes (left/down/up/right)
  Alt-[ / Alt-]     Previous/next swap layout (BASE <-> SPLIT)
  Alt-q             Open yazi in floating pane
  Alt-w             Open lazygit in floating pane

Core Zellij keys:
  Ctrl-n            Enter/exit resize mode
  h/j/k/l, +/-      Resize focused pane (in resize mode)
  F12              Open this workspace help popup
  Ctrl-d            Detach from session
  Ctrl-q            Quit Zellij

Tip:
  Run ws-help in any pane when needed.
  Fixed tabs auto-restore when you run ws.
  Use Alt-[ / Alt-] to switch between BASE and SPLIT layouts.
  opencode panes start suspended; press Enter in that pane to launch.
EOF

printf '\nPress Enter to close... '
IFS= read -r _
