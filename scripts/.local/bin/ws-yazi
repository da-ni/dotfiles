#!/usr/bin/env bash
set -euo pipefail

if ! command -v yazi >/dev/null 2>&1; then
  printf 'Error: yazi is required but was not found in PATH.\n' >&2
  exit 1
fi

if [[ "${1:-}" == "--float" ]]; then
  shift
fi

target_dir="${PWD:-$HOME}"
if command -v ws-current-cwd >/dev/null 2>&1; then
  target_dir="$(ws-current-cwd)"
fi

if [[ -d "$target_dir" ]]; then
  cd "$target_dir"
fi

context_name="$(basename "$target_dir")"
if [[ -n "${ZELLIJ:-}" ]]; then
  zellij action rename-pane "yazi:${context_name:-home}" >/dev/null 2>&1 || true
fi

lock_root="${XDG_RUNTIME_DIR:-/tmp}/ws-tool-locks"
mkdir -p "$lock_root"

if command -v sha256sum >/dev/null 2>&1; then
  lock_key="$(printf '%s' "$target_dir" | sha256sum | awk '{print $1}')"
elif command -v md5sum >/dev/null 2>&1; then
  lock_key="$(printf '%s' "$target_dir" | md5sum | awk '{print $1}')"
else
  lock_key="$(printf '%s' "$target_dir" | cksum | awk '{print $1}')"
fi

if command -v flock >/dev/null 2>&1; then
  lock_file="$lock_root/yazi-${lock_key}.lock"
  exec 9>"$lock_file"
  if ! flock -n 9; then
    exit 0
  fi
else
  lock_dir="$lock_root/yazi-${lock_key}.lockdir"
  lock_pid_file="$lock_dir/pid"

  acquire_dir_lock() {
    if mkdir "$lock_dir" 2>/dev/null; then
      printf '%s\n' "$$" >"$lock_pid_file"
      trap 'rm -rf -- "$lock_dir"' EXIT INT TERM
      return 0
    fi
    return 1
  }

  if ! acquire_dir_lock; then
    if [[ -f "$lock_pid_file" ]]; then
      lock_pid="$(cat "$lock_pid_file" 2>/dev/null || true)"
      if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
        exit 0
      fi
    fi

    rm -rf -- "$lock_dir"
    acquire_dir_lock || exit 0
  fi
fi

exec yazi
